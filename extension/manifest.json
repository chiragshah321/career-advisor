{
  "manifest_version": 3,
  "name": "CareerOS - Job Tracker",
  "version": "1.0.0",
  "description": "Save jobs to CareerOS with one click from any job listing page",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
