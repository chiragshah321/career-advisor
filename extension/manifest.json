{
  "manifest_version": 3,
  "name": "Rassel - Career Advisor",
  "version": "1.1.0",
  "description": "Save jobs and open quick-link tab groups with one click.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs", "tabGroups"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://app-black-six-21.vercel.app/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
